      <aliases enabled='yes' />
      <column caption='Section around' datatype='string' name='[Calculation_2826782839409963008]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='right([section],2)' />
      </column>
      <column caption='Is Less Than Highlight' datatype='boolean' name='[Calculation_2826782839411642369]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[total_price]&lt;=[Parameters].[Parameter 1]' />
      </column>
      <column caption='Golden Rows' datatype='string' name='[Calculation_4405294510054125568]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF REGEXP_MATCH([row], &quot;AA|BB|CC|DD|EE|FF|GG|[A-K]&quot;) THEN &quot;Proche&quot;&#10;ELSE &quot;Loin&quot;&#10;END' />
      </column>
      <column caption='Golden Sections' datatype='string' name='[Calculation_4405294510067675137]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_6531837957071544320] = &quot;1&quot; OR [Calculation_6531837957071544320] = &quot;2&quot; THEN&#10;  IF ([Calculation_2826782839409963008] &gt;= &quot;01&quot; AND [Calculation_2826782839409963008] &lt;= &quot;03&quot;) OR ([Calculation_2826782839409963008] &gt;= &quot;11&quot; AND [Calculation_2826782839409963008] &lt;= &quot;13&quot;) THEN &quot;B - Côté&quot;&#10;  ELSEIF [Calculation_2826782839409963008] &gt;= &quot;14&quot; AND [Calculation_2826782839409963008] &lt;= &quot;24&quot; THEN &quot;A - Or&quot;&#10;  ELSE &quot;C - Bronze&quot;&#10;  END&#10;ELSE&#10;  IF ([Calculation_2826782839409963008] &gt;= &quot;01&quot; AND [Calculation_2826782839409963008] &lt;= &quot;03&quot;) OR ([Calculation_2826782839409963008] &gt;= &quot;17&quot; AND [Calculation_2826782839409963008] &lt;= &quot;19&quot;) THEN &quot;B - Côté&quot;&#10;  ELSEIF [Calculation_2826782839409963008] &gt;= &quot;20&quot; AND [Calculation_2826782839409963008] &lt;= &quot;36&quot; THEN &quot;A - Or&quot;&#10;  ELSE &quot;C - Bronze&quot;&#10;  END&#10;END' />
      </column>
      <column caption='Event Month Year' datatype='datetime' name='[Calculation_4405294510072360962]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[event.date])' />
      </column>
      <column caption='Section Group' datatype='string' name='[Calculation_6531837957071544320]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([section],1)' />
      </column>
      <column caption='Short Title' datatype='string' name='[Calculation_6531837957071753217]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='mid([event.title],24)' />
      </column>
      <column caption='Price Rank' datatype='integer' name='[Calculation_6739285017283825664]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(AVG([total_price]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column aggregation='None' caption='Total Price (bin)' datatype='integer' name='[Total Price (bin)]' role='dimension' type='ordinal'>
